{
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp",
                "--api-key",
                "YOUR_API_KEY"
            ]
        },
        "shadcn": {
            "command": "npx",
            "args": [
                "shadcn@latest",
                "mcp"
            ]
        },
        "coolify": {
            "command": "npx",
            "args": [
                "-y",
                "@masonator/coolify-mcp"
            ],
            "env": {
                "COOLIFY_API_URL": "https://coolify.MUDE_AQUI/api/v1",
                "COOLIFY_API_TOKEN": "API_TOKEN_AQUI"
            }
        }
        //other mcp servers
    }
}
// setup mcp server in  ~/.gemini\antigravity\mcp_config.json